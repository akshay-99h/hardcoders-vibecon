# -----------------------------------------------------------------------------
# LLM Provider
# -----------------------------------------------------------------------------
# Set provider: "openai" (recommended for deployment) or "openrouter" (local)
LLM_PROVIDER=openai

# Model name for selected provider
LLM_MODEL=gpt-4o-mini

# Optional shared overrides
# LLM_API_KEY=
# LLM_BASE_URL=

# OpenAI credentials (recommended deployment path)
OPENAI_API_KEY=your_openai_api_key
OPENAI_BASE_URL=https://api.openai.com/v1

# OpenRouter credentials (optional local testing path)
# OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_APP_TITLE=Mission-Mode Platform
# OPENROUTER_HTTP_REFERER=https://your-app-domain.com

# -----------------------------------------------------------------------------
# App / DB / Auth
# -----------------------------------------------------------------------------
MONGO_URL=mongodb://localhost:27017/mission_platform
JWT_SECRET=change-this-in-production
ENVIRONMENT=development

# -----------------------------------------------------------------------------
# Voice provider
# -----------------------------------------------------------------------------
VOICE_PROVIDER=openai
# VOICE_API_KEY=if-empty-falls-back-to-OPENAI_API_KEY
STT_MODEL=whisper-1
TTS_MODEL=tts-1
TTS_VOICE=nova

# -----------------------------------------------------------------------------
# Stripe (test mode)
# -----------------------------------------------------------------------------
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PLUS_MONTHLY=price_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_BUSINESS_MONTHLY=price_...
STRIPE_CHECKOUT_SUCCESS_URL=http://localhost:3000/billing?checkout=success&session_id={CHECKOUT_SESSION_ID}
STRIPE_CHECKOUT_CANCEL_URL=http://localhost:3000/billing?checkout=cancel
STRIPE_BILLING_RETURN_URL=http://localhost:3000/billing

# -----------------------------------------------------------------------------
# Frontend URL + Email alerts
# -----------------------------------------------------------------------------
FRONTEND_BASE_URL=http://localhost:3000
CONTACT_US_PATH=/contact
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=rakshaai@axhost.com
LOGIN_ALERT_EMAIL_ENABLED=true
