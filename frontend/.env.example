# Optional explicit backend URL for deployments where frontend and backend are on different origins.
# Leave empty for local dev with package.json proxy.
REACT_APP_API_BASE_URL=

# Optional Stripe publishable test key fallback for UI status checks.
# Backend /api/billing/plans also returns publishable_key if configured there.
REACT_APP_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Optional canonical base URL used by deployment SEO tooling.
# Example: https://rakshaai.com
REACT_APP_SITE_URL=
